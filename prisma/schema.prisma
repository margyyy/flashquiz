generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StudyItemKind {
  FLASHCARD
  MULTIPLE_CHOICE
  TRUE_FALSE
}

enum GameContentMode {
  QUIZ
  FLASHCARD
  MIXED
}

enum GameRoomStatus {
  LOBBY
  DRAFT
  PLAYING
  FINISHED
}

model Subject {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sets        CardSet[]
  gameRooms   GameRoom[]

  @@map("subjects")
}

model CardSet {
  id          String      @id @default(cuid())
  subjectId   String
  name        String
  slug        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  items       StudyItem[]

  @@unique([subjectId, slug])
  @@index([subjectId])
  @@map("card_sets")
}

model StudyItem {
  id                   String        @id @default(cuid())
  setId                String
  kind                 StudyItemKind
  prompt               String
  answer               String?
  options              Json?
  correctOptionIndexes Int[]         @default([])
  allowMultiple        Boolean       @default(false)
  explanation          String?
  order                Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  set                  CardSet       @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([setId, order])
  @@map("study_items")
}

model GameRoom {
  id                    String          @id @default(cuid())
  code                  String          @unique
  subjectId             String
  mode                  GameContentMode
  status                GameRoomStatus  @default(LOBBY)
  hostPlayerId          String?
  contentSnapshot       Json
  pool                  Json
  turnOrder             String[]        @default([])
  currentTurnIndex      Int             @default(0)
  currentResponderIndex Int             @default(0)
  activeCard            Json?
  activeResponses       Json?
  timerEnabled          Boolean         @default(false)
  timerSeconds          Int             @default(30)
  responderDeadlineAt   DateTime?
  deckSize              Int             @default(8)
  expiresAt             DateTime
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  subject               Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  players               GamePlayer[]

  @@index([code])
  @@index([expiresAt])
  @@map("game_rooms")
}

model GamePlayer {
  id         String   @id @default(cuid())
  roomId     String
  username   String
  tokenHash  String
  joinOrder  Int
  score      Int      @default(0)
  deck       Json     @default("[]")
  draftOffer Json?
  draftPicks Int      @default(0)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  room       GameRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, username])
  @@index([roomId, joinOrder])
  @@map("game_players")
}
